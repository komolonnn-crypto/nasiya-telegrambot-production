# API Configuration
# VITE_API_URL=https://api.craftly.uz/api/bot
# VITE_API_BASE_URL=https://api.craftly.uz

## Set this to your locally running backend to use it instead of the remote API.
## The front-end will append endpoints like `/auth/telegram` to this value.
## Example: if your local server exposes /api/bot/auth/telegram then set
## VITE_API_URL=http://localhost:3000/api/bot
VITE_API_URL=your-production-backend-api-url
VITE_API_BASE_URL=your-production-backend-base-url

# App Configuration
VITE_APP_NAME=your-app-name
VITE_APP_VERSION=your-app-version

## For developer convenience you can enable local mock login (dev only).
VITE_ENABLE_LOCAL_LOGIN=your-enable-local-login-value
USE_MOCK_AUTH=your-use-mock-auth-value
